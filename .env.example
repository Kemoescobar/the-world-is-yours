# THE WORLD IS YOURS — Docker Compose (root)
# Copy:  Copy-Item .env.example .env
# Fill secrets from server/.env + client/.env (never commit .env)

# --- Ports (host) ---
API_PORT=4000
WEB_PORT=8080
# N8N_PORT=5678

NODE_ENV=production
TZ=Indian/Antananarivo

# CORS — must match the browser origin of `web`
CLIENT_URL=http://localhost:8080

# --- Supabase (external cloud — no Postgres in this compose) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...replace-with-service-role-key

# Auth allowlist (UUID from Supabase Authentication → Users)
OWNER_USER_ID=
# ALLOWED_USER_IDS=uuid1,uuid2

# Webhooks / n8n → API
WEBHOOK_API_KEY=replace-with-long-random-key
GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret

# Optional AI routes
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Client build args (baked into the nginx image at build time) ---
# Browser-facing URLs — use localhost host ports, not Docker service names
VITE_API_URL=http://localhost:4000/api
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...replace-with-anon-key

# --- Optional profile: n8n (`docker compose --profile n8n up`) ---
# Prefer Docker DNS when n8n shares this compose network:
TWIY_API_URL=http://api:4000/api
# Same value as WEBHOOK_API_KEY (required for n8n → API calls)
TWIY_WEBHOOK_KEY=
# OBSIDIAN_API_KEY=
# GENERIC_TIMEZONE=Indian/Antananarivo
