# Copy to n8n/.env (gitignored) and fill in secrets.
# docker compose --env-file .env up -d

# TWIY Railway API (trailing /api)
TWIY_API_URL=https://the-world-is-yours-production.up.railway.app/api

# Same value as WEBHOOK_API_KEY in server/.env (Railway)
TWIY_WEBHOOK_KEY=replace-with-webhook-api-key

# Obsidian Local REST API plugin key (optional until vault sync/write workflows run)
OBSIDIAN_API_KEY=

# Optional — only if a workflow calls Anthropic directly.
# revue-dominicale.json uses POST /ai/revue on Railway (no key needed here).
ANTHROPIC_API_KEY=

# Timezone for cron triggers
GENERIC_TIMEZONE=Indian/Antananarivo
TZ=Indian/Antananarivo

# Persist encryption across container recreates (generate once: openssl rand -hex 32)
# N8N_ENCRYPTION_KEY=
